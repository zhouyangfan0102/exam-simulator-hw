@echo off
setlocal
chcp 65001 >nul
cd /d "%~dp0"

powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -OutputFormat Text -EncodedCommand   2>nul

if errorlevel 1 (
  echo 关闭失败，请检查考试模拟器命令窗口是否仍然存在。
  pause
  exit /b 1
)

powershell.exe -NoProfile -Command "Start-Sleep -Seconds 2"
exit /b 0
